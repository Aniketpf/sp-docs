{
    "title": "Body",
    "body": {
        "required": true,
        "content": {
            "application/json": {
                "schema": {
                    "type": "object",
                    "required": ["eventId", "externalCandidateAssessmentId", "expiryInSeconds"],
                    "properties": {
                        "eventId": {
                            "type": "string",
                            "minLength": 1,
                            "example": "evt_1238912",
                            "description": "Client-provided event ID for duplicate prevention"
                        },
                        "externalCandidateAssessmentId": {
                            "type": "string",
                            "minLength": 1,
                            "example": "87487364234",
                            "description": "Candidate Assessment ID for which interview is to be created"
                        },
                        "expiryInSeconds": {
                            "type": "integer",
                            "minimum": 60,
                            "maximum": 864000,
                            "example": 864000,
                            "description": "Expiry time for the interview in seconds"
                        }
                    },
                    "title": "CreateInterviewItem"
                },
                "example": { "eventId": "evt_test_123", "externalCandidateAssessmentId": "87487364234", "expiryInSeconds": 86400 }
            }
        }
    }
}
