{
    "responses": {
        "200": {
            "description": "Credentials generated successfully",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "status": { "type": "string", "example": "success" },
                            "data": {
                                "type": "object",
                                "properties": {
                                    "client_id": { "type": "string", "example": "prism_client_abc123" },
                                    "client_secret": { "type": "string", "example": "secret_xyz789" }
                                }
                            }
                        },
                        "title": "GenerateCredentialsResponse"
                    }
                }
            }
        },
        "401": {
            "description": "Unauthorized - invalid or missing token",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "statusCode": { "type": "integer", "example": 401 },
                            "success": { "type": "boolean", "example": false },
                            "message": { "type": "string", "example": "Unauthorized - invalid or missing authentication token" },
                            "error": {
                                "type": "object",
                                "properties": {
                                    "code": { "type": "string", "example": "UNAUTHORIZED" },
                                    "details": { "type": "string", "example": "Invalid or expired token" }
                                }
                            }
                        },
                        "title": "UnauthorizedError"
                    }
                }
            }
        },
        "403": {
            "description": "Forbidden - insufficient permissions",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "statusCode": { "type": "integer", "example": 400, "description": "HTTP status code" },
                            "success": { "type": "boolean", "example": false, "description": "Always false for errors" },
                            "message": { "type": "string", "example": "Request validation failed", "description": "Human-readable error message" },
                            "error": {
                                "type": "object",
                                "properties": {
                                    "code": { "type": "string", "example": "VALIDATION_ERROR", "description": "Machine-readable error code" },
                                    "details": { "type": "string", "example": "Invalid request parameters", "description": "Detailed error information" }
                                }
                            }
                        },
                        "title": "ErrorResponse"
                    }
                }
            }
        },
        "404": {
            "description": "User not found",
            "content": {
                "application/json": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "statusCode": { "type": "integer", "example": 400, "description": "HTTP status code" },
                            "success": { "type": "boolean", "example": false, "description": "Always false for errors" },
                            "message": { "type": "string", "example": "Request validation failed", "description": "Human-readable error message" },
                            "error": {
                                "type": "object",
                                "properties": {
                                    "code": { "type": "string", "example": "VALIDATION_ERROR", "description": "Machine-readable error code" },
                                    "details": { "type": "string", "example": "Invalid request parameters", "description": "Detailed error information" }
                                }
                            }
                        },
                        "title": "ErrorResponse"
                    }
                }
            }
        }
    }
}
