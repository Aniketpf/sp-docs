{
    "title": "Body",
    "body": {
        "required": true,
        "content": {
            "application/json": {
                "schema": {
                    "type": "object",
                    "required": ["eventId", "interviewId", "expiryInSeconds"],
                    "properties": {
                        "eventId": { "type": "string", "minLength": 1, "example": "evt_regen_123", "description": "Event ID for duplicate prevention" },
                        "interviewId": { "type": "string", "minLength": 1, "example": "intv_987654", "description": "Interview ID which needs to be reset" },
                        "expiryInSeconds": {
                            "type": "integer",
                            "minimum": 60,
                            "maximum": 864000,
                            "example": 86400,
                            "description": "New expiry time for the interview in seconds"
                        }
                    },
                    "title": "RegenerateInterviewRequest"
                },
                "example": { "eventId": "evt_regen_123", "interviewId": "intv_987654", "expiryInSeconds": 86400 }
            }
        }
    }
}
